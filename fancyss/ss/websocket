#!/bin/sh
source /koolshare/scripts/base.sh
NEW_PATH=$(echo $PATH|tr ':' '\n'|sed '/opt/d;/mmc/d'|awk '!a[$0]++'|tr '\n' ':'|sed '$ s/:$//')
export PATH=${NEW_PATH}
LOGFILE=/koolshare/logs/remote_access_record.txt

mkdir -p /koolshare/logs

cmd() {
	local bin="$1"
	shift
	if ! command -v "${bin}" >/dev/null 2>&1; then
		case "${bin}" in
		ss_node_subscribe.sh|ss_online_update.sh)
			echo "订阅脚本缺失：${bin}"
			echo "可能原因：固件安全组件或其它程序删除了该脚本。"
			echo "建议处理：重新安装 fancyss，并尽量升级到较新的无 ASD 固件。"
			return 127
			;;
		esac
	fi
	"${bin}" "$@" 2>&1
	# ${@%%[[:space:]]*} ${@#*[[:space:]]} 2>&1
	# start-stop-daemon -S -b -x ${@%%[[:space:]]*} -- ${@#*[[:space:]]}
	# start-stop-daemon -S -x ss_config.sh -- start
}

clean_log() {
	[ $(wc -l "${LOGFILE}" | awk '{print $1}') -le "10000" ] && return
	local logdata=$(tail -n 2000 "${LOGFILE}")
	echo "$logdata" > ${LOGFILE} 2> /dev/null
	unset logdata
}

while read MSG;
do
	MSG="$(printf '%s' "${MSG}" | tr -d '\r')"
	IP_CIDR=$(ip addr show br0 2>/dev/null | grep -E "inet " | awk '{print $2}')
	IP_ADDR=${IP_CIDR%/*}
	IP_ADDR=${IP_ADDR%.*}
	RET_0=$(echo "${REMOTE_ADDR}" | grep "${IP_ADDR}")
	RET_1=$(echo "${MSG}" | grep "ws_ok")
	if [ -z "${RET_0}${RET_1}" ];then
		# 非lan用户访问，记录下
		RET_2=$(echo ${MSG} | grep "ss_status")
		if [ -z "${RET_2}" ];then
			echo "[$(date -R +%Y年%m月%d日\ %X)] $REMOTE_ADDR:$REMOTE_PORT → ${MSG}" >>${LOGFILE}
			clean_log
		fi
	fi
	RET_3=$(echo "${MSG}" | grep -Ew "wget|curl|socat|nc|eval|ssh|scp|sed|awk|dropbear|dd|ln|rm|mv|cp|cd|aria2c|printf|openssl|base64|nvram|dbus|service|ps|ifconfig|ping|yaml|log")
	RET_4=$(echo "${MSG}" | grep -E ">|<")
	if [ "${MSG}" == "show_message" ]; then
		echo "成功连接到路由器，当前时间：$(date -R +%Y年%m月%d日\ %X)"
		echo "服务器：$SERVER_NAME"
		echo "客户端：$REMOTE_ADDR"
		echo "浏览器：$HTTP_USER_AGENT"
		echo "$(env)"
		echo "请点击下方按钮执行操作！"
	elif [ "${MSG}" == "reboot" ]; then
		echo "检测到你要执行路由器重启命令！拒绝！"
		exit
	elif [ "${MSG}" == "get_ssf_log" ]; then
		awk 'BEGIN{ORS="@@"}{print}' /tmp/upload/ssf_status.txt 2>/dev/null
	elif [ "${MSG}" == "get_ssc_log" ]; then
		awk 'BEGIN{ORS="@@"}{print}' /tmp/upload/ssc_status.txt 2>/dev/null
	elif [ "${MSG}" == "get_real_log" ]; then
		_log=$(cat /tmp/upload/ss_log.txt)
		if [ -z "${_log}" ];then
			echo "开始获取日志！"
		else
			echo "${_log}"
		fi
	elif [ "${MSG}" == "follow_webtest" ]; then
		WEBTEST_FILE=/tmp/upload/webtest.txt
		WEBTEST_STREAM=/tmp/upload/webtest.stream
		[ -f "${WEBTEST_FILE}" ] || : >"${WEBTEST_FILE}"
		[ -f "${WEBTEST_STREAM}" ] || : >"${WEBTEST_STREAM}"
		LAST_STREAM_INODE=""
		LAST_STREAM_LINES=0
		IDLE_LOOPS=0
		if [ -f "${WEBTEST_FILE}" ]; then
			cat "${WEBTEST_FILE}" || exit 0
		fi
		if grep -q '^stop>stop$' "${WEBTEST_FILE}" 2>/dev/null; then
			exit 0
		fi
		while true
		do
			[ -f "${WEBTEST_FILE}" ] || : >"${WEBTEST_FILE}"
			[ -f "${WEBTEST_STREAM}" ] || : >"${WEBTEST_STREAM}"
			STREAM_INODE=$(ls -i "${WEBTEST_STREAM}" 2>/dev/null | awk '{print $1}')
			if [ -z "${STREAM_INODE}" ]; then
				sleep 1
				continue
			fi
			if [ "${STREAM_INODE}" != "${LAST_STREAM_INODE}" ]; then
				LAST_STREAM_INODE="${STREAM_INODE}"
				LAST_STREAM_LINES=0
			fi
			STREAM_LINES=$(wc -l < "${WEBTEST_STREAM}" 2>/dev/null)
			[ -n "${STREAM_LINES}" ] || STREAM_LINES=0
			if [ "${STREAM_LINES}" -gt "${LAST_STREAM_LINES}" ]; then
				sed -n "$((LAST_STREAM_LINES + 1)),${STREAM_LINES}p" "${WEBTEST_STREAM}" 2>/dev/null | while IFS= read -r line
				do
					[ -n "${line}" ] || continue
					echo "${line}" || exit 0
					[ "${line}" = "stop>stop" ] && exit 0
				done
				LAST_STREAM_LINES="${STREAM_LINES}"
				IDLE_LOOPS=0
			elif [ -f "/tmp/webtest.lock" ]; then
				IDLE_LOOPS=0
			else
				IDLE_LOOPS=$((IDLE_LOOPS + 1))
			fi
			if grep -q '^stop>stop$' "${WEBTEST_FILE}" 2>/dev/null; then
				exit 0
			fi
			if [ "${IDLE_LOOPS}" -ge 8 ]; then
				exit 0
			fi
			sleep 1
		done
		exit 0
	elif [ "${MSG}" == "follow_shunt_stats" ]; then
		while true
		do
			sh /koolshare/scripts/ss_shunt_stats.sh ws
			sleep 6
		done
		exit 0
	elif [ "${MSG}" == "follow_ssf_status" -o "${MSG}" == "follow_ssc_status" ]; then
		if [ "${MSG}" = "follow_ssf_status" ]; then
			STATUS_FILE=/tmp/upload/ssf_status.txt
			STATUS_STREAM=/tmp/upload/ssf_status.stream
		else
			STATUS_FILE=/tmp/upload/ssc_status.txt
			STATUS_STREAM=/tmp/upload/ssc_status.stream
		fi
		[ -f "${STATUS_FILE}" ] || : > "${STATUS_FILE}"
		[ -f "${STATUS_STREAM}" ] || : > "${STATUS_STREAM}"
		awk '
			BEGIN {
				print "__FSS_SNAPSHOT_BEGIN__"
				chunk = ""
				count = 0
			}
			{
				gsub(/\r/, "")
				chunk = chunk $0 "__FSS_NL__"
				count++
				if (count >= 64) {
					print "__FSS_SNAPSHOT_CHUNK__" chunk
					chunk = ""
					count = 0
				}
			}
			END {
				if (count > 0) {
					print "__FSS_SNAPSHOT_CHUNK__" chunk
				}
				print "__FSS_SNAPSHOT_END__"
			}
		' "${STATUS_FILE}" 2>/dev/null
		STATUS_LINES=$(wc -l < "${STATUS_STREAM}" 2>/dev/null)
		[ -n "${STATUS_LINES}" ] || STATUS_LINES=0
		tail -n +"$((STATUS_LINES + 1))" -f "${STATUS_STREAM}" 2>/dev/null | while IFS= read -r line
		do
			echo "${line}"
		done
		exit 0
	elif [ -n "${RET_3}" -o -n "${RET_4}" ]; then
		echo "不允许命令：${MSG}"
		exit
	else
		cmd $MSG
	fi
done
