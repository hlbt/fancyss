			var xrayLabel = (c["xray_prot"] || "vless") == "vmess" ? "Vmess" : "Vless";
			option0.append($("<option>", {
				value: field,
				text: c["xray_use_json"] == "1" ? "【json】" + group_tag + c.name : "【" + xrayLabel + "】" + group_tag + c.name
			}));
		}
		else if(c.type == "5"){
			//trojan
			option0.append($("<option>", {
				value: field,
				text: "【Trojan】" + group_tag + c.name
			}));
		}
			else if(c.type == "6"){																								//fancyss-full							
