	//first: mark all node from ss_nodes data as empty
	for (var i = 0; i < tr.length; i++) {
		var rowid = tr[i].getAttribute("id").split("_")[1];
		for (var j = 0; j < temp.length; j++) {
			dbus_tmp[perf + temp[j] + "_" + rowid] = "";
