		return;
	}
	E("ssconf_basic_node").value = node_sel;
	var obj = ssconf_node2obj(node_sel);
	conf2obj(obj, 1);
	verifyFields();
	refresh_basic_method_width();
	refresh_basic_input_width();
	refresh_shunt_ui();
