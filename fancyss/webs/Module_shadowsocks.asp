	var socket = shuntStatsWs;
	clear_shunt_stats_ws_timers();
	if (!socket) {
		return;
	}
	shuntStatsWsClosing = triggerFallback ? false : true;
	shuntStatsWs = null;
	try {
		socket.onopen = null;
		socket.onmessage = null;
		socket.onerror = null;
		socket.onclose = null;
		socket.close();
	} catch (e) {}
}
function stop_shunt_stats_runtime() {
