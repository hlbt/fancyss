function refresh_node_panel(cb) {
	return $.ajax({
		type: "GET",
		url: "/_api/ss",
		dataType: "json",
		success: function(data) {
			db_ss = data.result[0];
			normalize_latency_val();
			refresh_fss_bundle(function() {
				generate_node_info();
